      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(shutdown *)",
      "Bash(sudo *)",
      "Bash(twine upload *)"
    ],
    "ask": [
      "Bash(DROP TABLE *)",
      "Bash(conda remove *)",
      "Bash(conda uninstall *)",
      "Bash(docker rm -f *)",
      "Bash(docker stop *)",
      "Bash(gh issue close *)",
      "Bash(gh pr close *)",
      "Bash(gh pr merge *)",
      "Bash(gh repo delete *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git stash clear)",
      "Bash(git stash drop *)",
      "Bash(git tag -d *)",
      "Bash(kubectl delete *)",
      "Bash(pip uninstall *)",
      "Bash(rm *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-wsl.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf '=== Post-compaction reminders ===\n- Use pathlib over os.path\n- Always add docstrings (Google-style)\n- Use type hints on function signatures\n- Run tests after making changes\n- Make incremental commits for each unit of work\n- Never delete files without asking first\n'"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Session Context ===' && (git rev-parse --is-inside-work-tree >/dev/null 2>&1 && echo \"Branch: $(git branch --show-current)\" && echo \"Status:\" && git status --short || echo 'Not a git repo') && echo '---' && (conda info --envs 2>/dev/null | grep '*' || echo 'No active conda env')"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-bash-command.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-sensitive-file.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/freeze-boundary.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format-code.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-mode-exit.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-pi-stack-handoff.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-completion.py"
          }
        ]
      }
    ]
  },
  "defaultMode": "plan",
  "effortLevel": "max"
}
