      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git restore .)",
      "Bash(kubectl delete namespace *)",
      "Bash(mkfs *)",
      "Bash(npm publish *)",
      "Bash(npm publish)",
      "Bash(reboot *)",
